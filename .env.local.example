# Copy this file to .env.local and fill in the values.
# The app runs in manual-paste-only mode when API keys are omitted.

# ── Firebase (required for live Firestore sync) ──────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyANYmf4sBalVVHFBEkwjXYLywFkFRFl4IA
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=venezuela-rescue-2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=venezuela-rescue-2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=venezuela-rescue-2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=62443143381
NEXT_PUBLIC_FIREBASE_APP_ID=1:62443143381:web:d8f608c5d9e2a89ad0a25c

# ── Twitter / X API v2 (optional) ────────────────────────────────────────────
# Bearer token from developer.twitter.com — Basic or Pro plan required for
# recent-search access. Without this, Twitter is skipped silently.
TWITTER_BEARER_TOKEN=

# ── Apify (optional) ─────────────────────────────────────────────────────────
# API token from console.apify.com — used for Instagram, Facebook, TikTok.
# Each scrape run costs Apify credits; free tier usually covers low volume.
APIFY_API_TOKEN=

# ── Telegram Bot (optional) ──────────────────────────────────────────────────
# Create a bot via @BotFather and add it as admin to each channel you want
# to monitor. Without this, Telegram is skipped silently.
TELEGRAM_BOT_TOKEN=
